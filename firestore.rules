rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function nonEmptyString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function stringWithin(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function validCaseStatus(value) {
      return value == "Missing" || value == "Found" || value == "Under Investigation";
    }

    function validChappalType(value) {
      return value == "Hawai Chappal" ||
        value == "Bathroom Slipper" ||
        value == "Crocs" ||
        value == "Sandal" ||
        value == "Sports Shoes" ||
        value == "School Shoes" ||
        value == "Unknown Species";
    }

    function validCrimeScene(value) {
      return value == "Temple" ||
        value == "Mosque" ||
        value == "Wedding" ||
        value == "Hostel" ||
        value == "Tuition" ||
        value == "Friend's House" ||
        value == "House Party" ||
        value == "Other";
    }

    function validTipKind(value) {
      return value == "preset" || value == "custom";
    }

    function validTipPresetKey(value) {
      return value == "saw-nearby" ||
        value == "check-rack" ||
        value == "uncle-involvement" ||
        value == "friend-prank" ||
        value == "emotionally-moved-on";
    }

    function validReportReason(value) {
      return value == "real-info" ||
        value == "real-person" ||
        value == "harassment" ||
        value == "spam";
    }

    match /cases/{caseId} {
      allow read: if true;

      allow create: if isAuthed() &&
        caseId.matches("^CHPL-[A-Z0-9]{6}$") &&
        request.resource.data.keys().hasOnly([
          "caseId",
          "nickname",
          "type",
          "color",
          "area",
          "crimeScene",
          "lastSeenClue",
          "reward",
          "instagramHandle",
          "createdByUid",
          "status",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.caseId == caseId &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.status == "Missing" &&
        nonEmptyString(request.resource.data.nickname, 40) &&
        validChappalType(request.resource.data.type) &&
        nonEmptyString(request.resource.data.color, 40) &&
        nonEmptyString(request.resource.data.area, 40) &&
        validCrimeScene(request.resource.data.crimeScene) &&
        nonEmptyString(request.resource.data.lastSeenClue, 100) &&
        nonEmptyString(request.resource.data.reward, 40) &&
        stringWithin(request.resource.data.instagramHandle, 30) &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp;

      allow update: if isAuthed() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "updatedAt"
        ]) &&
        request.resource.data.caseId == resource.data.caseId &&
        request.resource.data.nickname == resource.data.nickname &&
        request.resource.data.type == resource.data.type &&
        request.resource.data.color == resource.data.color &&
        request.resource.data.area == resource.data.area &&
        request.resource.data.crimeScene == resource.data.crimeScene &&
        request.resource.data.lastSeenClue == resource.data.lastSeenClue &&
        request.resource.data.reward == resource.data.reward &&
        request.resource.data.instagramHandle == resource.data.instagramHandle &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        validCaseStatus(request.resource.data.status) &&
        request.resource.data.updatedAt is timestamp;

      allow delete: if false;

      match /tips/{tipId} {
        allow read: if true;

        allow create: if isAuthed() &&
          exists(/databases/$(database)/documents/cases/$(caseId)) &&
          request.resource.data.keys().hasOnly([
            "caseId",
            "kind",
            "presetKey",
            "message",
            "createdByUid",
            "createdAt"
          ]) &&
          request.resource.data.caseId == caseId &&
          request.resource.data.createdByUid == request.auth.uid &&
          validTipKind(request.resource.data.kind) &&
          nonEmptyString(request.resource.data.message, 120) &&
          (
            (request.resource.data.kind == "preset" &&
              validTipPresetKey(request.resource.data.presetKey)) ||
            (request.resource.data.kind == "custom" &&
              request.resource.data.presetKey == "")
          ) &&
          request.resource.data.createdAt is timestamp;

        allow update, delete: if false;
      }

      match /reports/{reportId} {
        allow read: if false;

        allow create: if isAuthed() &&
          exists(/databases/$(database)/documents/cases/$(caseId)) &&
          request.resource.data.keys().hasOnly([
            "reason",
            "note",
            "createdByUid",
            "createdAt"
          ]) &&
          request.resource.data.createdByUid == request.auth.uid &&
          validReportReason(request.resource.data.reason) &&
          stringWithin(request.resource.data.note, 80) &&
          request.resource.data.createdAt is timestamp;

        allow update, delete: if false;
      }
    }
  }
}
